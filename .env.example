# Kalshi API credentials
# Get your API key from: https://kalshi.com (Account -> API Keys)
# The demo environment uses keys created at https://demo.kalshi.co

# Your API key ID (UUID shown when you create the key)
KALSHI_KEY_ID=your-key-id-here

# Absolute path to the RSA private key file (.pem) downloaded when creating the key
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# API base URL. Demo (paper trading) by default; switch to
# https://api.elections.kalshi.com/trade-api/v2 for production.
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# ----- Bot strategy settings -----

# Market the bot trades (find tickers via GET /api/markets or kalshi.com)
BOT_MARKET_TICKER=

# Contracts to buy per entry
BOT_ORDER_COUNT=10

# Buy YES when the ask drops below this (cents = implied probability %)
BOT_BUY_THRESHOLD=30

# Sell YES when the bid reaches this or higher
BOT_SELL_THRESHOLD=70

# Seconds between market checks (v2 ignores this — fixed at 2s per market thread)
BOT_POLL_SECONDS=15

# ----- AI market selection (Feature 2) -----

# OpenRouter API key for GPT-4o-mini market recommendations
# Get one at https://openrouter.ai/keys
# Leave blank to disable AI selection (bot will only trade BOT_MARKET_TICKER)
OPENROUTER_API_KEY=

# ----- Backtesting -----

# Set to true and run `python bot_strategy.py` to replay historical prices
# for BOT_MARKET_TICKER through the strategy instead of trading live
BACKTEST_MODE=false

# How many days of trade history to replay
BACKTEST_DAYS=30
